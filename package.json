{
  "name": "lucky-now",
  "version": "1.0.0",
  "private": true,
  "description": "体彩开奖查询微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "Sass",
    "framework": "Vue3"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{js,ts,vue,scss,css,json}\" \"config/**/*.{js,ts}\" \"*.{js,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,scss,css,json}\" \"config/**/*.{js,ts}\" \"*.{js,mjs,json,md}\"",
    "lint": "eslint src config --ext .js,.ts,.vue",
    "lint:fix": "eslint src config --ext .js,.ts,.vue --fix",
    "check": "npm run format:check && npm run lint",
    "new": "taro new",
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:harmony-hybrid": "taro build --type harmony-hybrid",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:harmony-hybrid": "npm run build:harmony-hybrid -- --watch"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "lint-staged": {
    "*.{js,ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,scss,css,mjs}": "prettier --write"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@nutui/nutui-taro": "^4.3.14",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-vue3": "4.2.0",
    "@tarojs/plugin-html": "^4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-harmony-hybrid": "4.2.0",
    "@tarojs/plugin-platform-jd": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nutui/auto-import-resolver": "^1.0.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-generator": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/test-utils-vue3": "^0.1.1",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/minimatch": "^5",
    "@types/node": "^18",
    "@types/webpack-env": "^1.13.6",
    "@vue/babel-plugin-jsx": "^1.2.2",
    "@vue/compiler-sfc": "^3.0.0",
    "babel-preset-taro": "4.2.0",
    "css-loader": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-vue": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "sass": "^1.75.0",
    "style-loader": "^3.3.4",
    "stylelint": "^16.4.0",
    "stylelint-config-standard": "^38.0.0",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "^5.4.5",
    "unplugin-vue-components": "^32.1.0",
    "vue-loader": "^17.4.2",
    "webpack": "5.91.0"
  }
}
